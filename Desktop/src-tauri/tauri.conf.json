{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "neuro-karaoke-app",
  "version": "0.1.0",
  "identifier": "com.soul.neurokaraoke",
  "build": {
    "frontendDist": "../assets"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "headers": {},
      "capabilities": [
        {
          "$schema": "../gen/schemas/desktop-schema.json",
          "identifier": "default",
          "description": "default",
          "webviews": ["main"],
          "remote": {
            "urls": [
              "https://neurokaraoke.com/*",
              "https://*.neurokaraoke.com/*"
            ]
          },
          "permissions": [
            "core:default",
            "core:window:allow-minimize",
            "core:window:allow-close",
            "core:window:allow-toggle-maximize",
            "core:window:allow-show",
            "core:window:allow-start-dragging"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../assets/icon.png",
      "../assets/icon.ico",
      "../assets/icon.icns"
    ],
    "resources": [
      "../assets/**/*"
    ]
  }
}
