<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        tools:node="merge">

        <!-- Phone activity removed on AAOS — replaced by custom Compose launcher -->
        <activity
            android:name="com.soul.neurokaraoke.MainActivity"
            tools:node="remove" />

        <!-- AAOS launcher: custom Compose UI tuned for car screens -->
        <activity
            android:name="com.soul.neurokaraoke.aaos.AaosLauncherActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:launchMode="singleTask"
            android:resizeableActivity="true"
            android:theme="@style/Theme.NeuroKaraoke">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Discord OAuth callback -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="neurokaraoke" android:host="auth" />
            </intent-filter>
            <meta-data
                android:name="distractionOptimized"
                android:value="true" />
        </activity>
    </application>
</manifest>
